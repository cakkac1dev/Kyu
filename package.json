{
  "name": "anixart-desktop",
  "version": "1.0.1",
  "description": "Десктоп-клиент для просмотра аниме на основе AniXart API",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "portable": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kyu.desktop",
    "productName": "Kyu",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Kyu-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Kyu-${version}-portable.exe"
    },
    "compression": "maximum"
  }
}
